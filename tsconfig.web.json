{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/shared/**/*",
    "src/renderer/src/features/**/*",
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./src/renderer/src/*"
      ],
      "@renderer/*": [
        "./src/renderer/src/*"
      ],
      "@main/*": [
        "./src/main/*"
      ],
      "@preload/*": [
        "./src/preload/*"
      ],
      "@shared/*": [
        "./src/shared/*"
      ],
      "@features/*": [
        "./src/renderer/src/features/*"
      ],
    }
  }
}
